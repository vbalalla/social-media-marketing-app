# =============================================================================
# Serendia Social Dashboard — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=serendia
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production

# --- JWT (RS256) ---
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=REPLACE_WITH_BASE64_ENCODED_PEM
JWT_PUBLIC_KEY=REPLACE_WITH_BASE64_ENCODED_PEM
JWT_ISSUER=https://api.serendia.io
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# --- Meta (Facebook/Instagram) OAuth ---
META_APP_ID=REPLACE_WITH_META_APP_ID
META_APP_SECRET=REPLACE_WITH_META_APP_SECRET
META_REDIRECT_URI=http://localhost:8080/api/social/oauth/meta/callback

# --- TikTok OAuth ---
TIKTOK_CLIENT_KEY=REPLACE_WITH_TIKTOK_CLIENT_KEY
TIKTOK_CLIENT_SECRET=REPLACE_WITH_TIKTOK_CLIENT_SECRET
TIKTOK_REDIRECT_URI=http://localhost:8080/api/social/oauth/tiktok/callback

# --- LinkedIn OAuth ---
LINKEDIN_CLIENT_ID=REPLACE_WITH_LINKEDIN_CLIENT_ID
LINKEDIN_CLIENT_SECRET=REPLACE_WITH_LINKEDIN_CLIENT_SECRET
LINKEDIN_REDIRECT_URI=http://localhost:8080/api/social/oauth/linkedin/callback

# --- X (Twitter) OAuth ---
X_CLIENT_ID=REPLACE_WITH_X_CLIENT_ID
X_CLIENT_SECRET=REPLACE_WITH_X_CLIENT_SECRET
X_REDIRECT_URI=http://localhost:8080/oauth/callback

# --- Internal Service Secret ---
INTERNAL_SERVICE_SECRET=super-secret-service-key

# --- LLM Provider ---
LLM_PROVIDER=openai   # openai | gemini
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY
GEMINI_API_KEY=REPLACE_WITH_GEMINI_API_KEY

# --- AWS (for Secrets Manager & S3) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE
AWS_SECRET_ACCESS_KEY=REPLACE
S3_BUCKET_NAME=serendia-media-assets

# --- Token Encryption ---
TOKEN_ENCRYPTION_MASTER_KEY=REPLACE_WITH_32_BYTE_HEX_KEY

# --- Service Ports (local dev) ---
AUTH_SERVICE_PORT=8081
CORE_SERVICE_PORT=8082
AI_SERVICE_PORT=8083
AD_SERVICE_PORT=8084
INBOX_SERVICE_PORT=8085
WEB_PORT=3000
GATEWAY_PORT=8080

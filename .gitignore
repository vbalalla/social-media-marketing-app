# =============================================================================
# Serendia Social Dashboard — Monorepo .gitignore
# Stack: Spring Boot (Java/Maven) · React (Vite/TypeScript) · Docker · Terraform
# =============================================================================

# -----------------------------------------------------------------------------
# Java / Spring Boot / Maven
# -----------------------------------------------------------------------------
target/
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*

# Maven wrapper
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# Spring Boot
application-local.yml
application-local.properties
application-secrets.yml

# -----------------------------------------------------------------------------
# Node.js / React / Vite / pnpm
# -----------------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
build/
.pnpm-store/
.pnpm-debug.log*

# Vite
*.local
vite.config.ts.timestamp-*

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# TypeScript
*.tsbuildinfo

# Playwright
/playwright-report/
/blob-report/
/playwright/.cache/
test-results/

# Vitest / coverage
coverage/
lcov.info

# -----------------------------------------------------------------------------
# Environment & Secrets — NEVER COMMIT THESE
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.p12
*.jks
secrets/
*secret*
*credential*

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.docker/
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Kubernetes / Helm
# -----------------------------------------------------------------------------
infra/helm/charts/*.tgz
infra/terraform/.terraform/
infra/terraform/*.tfstate
infra/terraform/*.tfstate.backup
infra/terraform/*.tfvars
!infra/terraform/*.tfvars.example
infra/terraform/.terraform.lock.hcl

# -----------------------------------------------------------------------------
# IDEs & Editors
# -----------------------------------------------------------------------------

# IntelliJ IDEA / WebStorm / DataGrip
.idea/
*.iws
*.iml
*.ipr
out/

# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# Eclipse
.project
.classpath
.settings/

# Vim / Emacs
*.swp
*.swo
*~
\#*\#

# -----------------------------------------------------------------------------
# OS & System Files
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# -----------------------------------------------------------------------------
# Logs & Temporary Files
# -----------------------------------------------------------------------------
logs/
*.log
*.log.*
tmp/
temp/
.cache/
.nyc_output/

# Gatling reports
results/
